# 服务器端口
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
TRUST_PROXY=0

# 浏览器管理端和 Flutter Web 的允许来源，多个地址用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jielong

# JWT 密钥配置
JWT_SECRET=generate_a_random_secret_with_at_least_32_characters
JWT_EXPIRES_IN=7d

# 管理员 JWT 密钥（与普通用户分离，增强安全性）
ADMIN_JWT_SECRET=generate_another_random_secret_with_at_least_32_characters

# 管理员登录名。初始密码仅在执行 create:admin 时临时设置，不要写入此文件。
ADMIN_USERNAME=admin
