# Server
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
TRUST_PROXY=1

# Browser origins allowed to call the API.
# Use HTTPS production domains only, separated by commas.
CORS_ORIGINS=https://admin.example.com

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=jielong_app
DB_PASSWORD=
DB_NAME=jielong

# JWT secrets. Generate different strong random values for both.
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=

# Admin username. Initial password is provided only when running npm run create:admin.
ADMIN_USERNAME=admin

# Third-party integrations. Fill these on the server only after contracts are ready.
SMS_PROVIDER=
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

AD_PROVIDER=
AD_APP_ID=
AD_CALLBACK_SECRET=

WITHDRAW_PROVIDER=manual
